# Rust build artifacts
/target
**/*.rs.bk

# Runtime output (checkpoints, samples, adapters)
/output
# loractl-api's default LORACTL_OUTPUT_BASE — `just serve` from the repo root
# creates ./runs at startup (see AppState::new / #37 output confinement).
/runs

# Real-GPT-2 parity fixtures (~500 MB safetensors + its golden) are generated
# locally by `just gpt2-reference` for the opt-in `gpt2-real` test — never
# committed. The tiny-GPT-2 fixture IS committed (see tests/fixtures/tiny-gpt2/).
/crates/loractl-core/tests/fixtures/gpt2-real/
/crates/loractl-core/tests/fixtures/gpt2_real_golden.json

# Local, uncommitted training configs (keep config/examples/ tracked)
/config/*.yaml
!/config/examples/

# Editor / OS
.DS_Store

# Claude Code runtime state (managed by /configure:gitignore)
.claude/worktrees/
/worktrees/
.claude/scheduled_tasks.lock
.claude/settings.local.json

# Blueprint: work-orders are task-specific and may hold sensitive detail
docs/blueprint/work-orders/
