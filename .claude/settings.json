{
  "permissions": {
    "allow": [
      "Bash(cargo build:*)",
      "Bash(cargo check:*)",
      "Bash(cargo test:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo run:*)",
      "Bash(cargo tree:*)",
      "Bash(cargo update:*)",
      "Bash(cargo audit:*)",
      "Bash(cargo deny:*)",
      "Bash(cargo llvm-cov:*)",
      "Bash(cargo doc:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git switch:*)",
      "Bash(git restore:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git branch:*)",
      "Bash(git push:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh run:*)",
      "Bash(gh workflow:*)",
      "Bash(gh release:*)",
      "Bash(just:*)",
      "Bash(pre-commit:*)",
      "Bash(gitleaks:*)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push -f *)"
    ]
  },
  "extraKnownMarketplaces": {
    "laurigates-claude-plugins": {
      "source": { "source": "github", "repo": "laurigates/claude-plugins" },
      "autoUpdate": true
    }
  },
  "enabledPlugins": {
    "blueprint-plugin@laurigates-claude-plugins": true,
    "code-quality-plugin@laurigates-claude-plugins": true,
    "configure-plugin@laurigates-claude-plugins": true,
    "git-plugin@laurigates-claude-plugins": true,
    "health-plugin@laurigates-claude-plugins": true,
    "hooks-plugin@laurigates-claude-plugins": true,
    "rust-plugin@laurigates-claude-plugins": true,
    "testing-plugin@laurigates-claude-plugins": true
  }
}
